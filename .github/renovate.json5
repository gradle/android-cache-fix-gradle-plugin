{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "github>gradle/renovate-agent//presets/dv-automerge-minor.json5",
    ":disableDependencyDashboard",
  ],
  "ignorePresets": [
    // Ignore for versions.json to be parsed (inherited from config:recommended)
    ":ignoreModulesAndTests",
  ],
  "branchPrefix": "renovatebot/",
  // Renovate handles all dependency updates.
  "enabledManagers": ["custom.regex", "gradle-wrapper", "gradle", "github-actions"],
  "customManagers": [
    {
      // Matches AGP versions in files with custom patterns
      customType: "regex",
      fileMatch: [
        "src/test/resources/versions\\.json",
        "gradle\\.properties",
      ],
      "matchStrings": [
        // In versions.json, matches keys with a list value, e.g. "8.9.0": [
        "\\s*?\"(?<currentValue>\\S+?)\"\\s*:\\s*\\[",
        // In gradle.properties, matches a specific property's value
        "org\\.gradle\\.android\\.latestKnownAgpVersion=(?<currentValue>\\S+?)(?:\\s|$)",
      ],
      "datasourceTemplate": "maven",
      "versioningTemplate": "maven",
      "depNameTemplate": "com.android.tools.build:gradle",
      "registryUrlTemplate": "https://dl.google.com/dl/android/maven2/",
    },
  ],
  // Ensure patches to older minors are opened, even if a newer minor is available
  // In versions.json, means older minors will still be checked for a newer patch
  "separateMinorPatch": true,
  "packageRules": [
    {
      // In versions.json, disable bumps of major/minor, which should be added as new properties
      "matchDepNames": ["com.android.tools.build:gradle"],
      "matchUpdateTypes": ["major", "minor"],
      "matchFileNames": ["src/test/resources/versions\\.json"],
      "enabled": false,
    },
    {
      // Allow unstable AGP versions to be used for tests
      "matchDepNames": ["com.android.tools.build:gradle"],
      "matchFileNames": [
        "src/test/resources/versions\\.json",
        "gradle\\.properties",
      ],
      "ignoreUnstable": false,
    },
    {
      // AGP is managed by the custom regex manager for the test matrix
      "matchManagers": ["gradle"],
      "matchDepNames": ["com.android.tools.build:gradle"],
      "enabled": false,
    },
    {
      // When the `latestKnownAgpVersion` property in gradle.properties is
      // bumped, run a post-upgrade script to keep versions.json and the
      // expectedOutcomes files in sync. See .github/renovate/post-upgrade.sh
      // for the full rationale. Scoped strictly to gradle.properties so the
      // hook does NOT fire for the separate versions.json key bumps the
      // custom regex manager produces for older minors.
      "matchDepNames": ["com.android.tools.build:gradle"],
      "matchFileNames": ["gradle.properties"],
      "postUpgradeTasks": {
        "commands": ["bash .github/renovate/post-upgrade.sh"],
        "fileFilters": [
          "src/test/resources/versions.json",
          "src/test/resources/expectedOutcomes/*.json",
        ],
        "executionMode": "update",
      },
    },
    {
      // Gradle plugins must use Groovy 4
      // https://docs.gradle.org/current/userguide/compatibility.html#groovy
      "matchPackagePatterns": ["^org\\.spockframework:"],
      "allowedVersions": "/groovy-4/",
    },
    {
      "matchManagers": ["gradle"],
      "groupName": "Gradle dependencies"
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions"
    }
  ],
}
